@inject IAsteriskServerService AsteriskService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <img src="img/asterisk.png" height="24" alt="" />
            AsteriskConsole
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="call-monitor">
                <span class="bi bi-telephone" aria-hidden="true"></span> Call Monitor
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="users">
                <span class="bi bi-people" aria-hidden="true"></span> Users
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="queues">
                <span class="bi bi-list-ol" aria-hidden="true"></span> Queues
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="trunks">
                <span class="bi bi-diagram-3" aria-hidden="true"></span> Trunks
            </NavLink>
