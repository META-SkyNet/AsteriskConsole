@page "/call-monitor"
@inject IAsteriskServerService AsteriskService
@implements IDisposable

<PageTitle>Call Monitor — AsteriskConsole</PageTitle>

<h1>Call Monitor</h1>

@if (!AsteriskService.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a href="connect">Connect →</a></div>
}
else
{
    <div class="row g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Active Channels (@_channels.Count)</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="Refresh">⟳ Refresh</button>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Channel</th>
                                <th>Account</th>
                                <th>State</th>
                                <th>Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!_channels.Any())
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">No active channels</td></tr>
                            }
                            @foreach (var ch in _channels)
                            {
                                <tr>
                                    <td><code class="small">@ch.Name</code></td>
                                    <td>@ch.Account</td>
                                    <td><span class="badge bg-@StateColor(ch.State.ToString())">@ch.State</span></td>
                                    <td>@FormatDuration(ch.DateOfCreation)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Parked Calls (@_parkedCalls.Count)</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Extension</th><th>Channel</th><th>Caller ID</th></tr></thead>
                        <tbody>
                            @foreach (var p in _parkedCalls)
                            {
                                <tr>
                                    <td>@p.Exten</td>
                                    <td><code class="small">@p.Channel</code></td>
                                    <td>@p.CallerId</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Meet Me Rooms (@_meetMeRooms.Count)</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Room</th><th>Users</th></tr></thead>
                        <tbody>
                            @foreach (var r in _meetMeRooms)
                            {
                                <tr>
                                    <td>@r.RoomNumber</td>
                                    <td>@(r.GetUsers()?.Count ?? 0)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<AsteriskChannel> _channels = [];
    private IReadOnlyList<ParkedCall> _parkedCalls = [];
    private IReadOnlyList<AsteriskMeetMeRoom> _meetMeRooms = [];
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        AsteriskService.StateChanged += OnStateChanged;
        Refresh();
        _timer = new System.Threading.Timer(_ =>
            InvokeAsync(() => { Refresh(); StateHasChanged(); }), null, 3000, 3000);
    }

    private void Refresh()
    {
        _channels = AsteriskService.GetActiveChannels();
        _parkedCalls = AsteriskService.GetParkedCalls();
        _meetMeRooms = AsteriskService.GetMeetMeRooms();
    }

    private void OnStateChanged(object? sender, string state) =>
        InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private static string StateColor(string? state) => state?.ToLower() switch
    {
        "up" => "success",
        "ring" => "warning",
        "down" => "secondary",
        _ => "primary"
    };

    private static string FormatDuration(DateTime? created) =>
        created.HasValue
            ? (DateTime.Now - created.Value).ToString(@"hh\:mm\:ss")
            : "--";

    public void Dispose()
    {
        _timer?.Dispose();
        AsteriskService.StateChanged -= OnStateChanged;
    }
}
