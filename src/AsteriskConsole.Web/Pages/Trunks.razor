@page "/trunks"
@inject IAsteriskServerService AsteriskService
@implements IDisposable

<PageTitle>Trunks — AsteriskConsole</PageTitle>

<h1>Trunks</h1>

@if (!AsteriskService.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a href="connect">Connect →</a></div>
}
else
{
    <div class="card">
        <div class="card-header d-flex justify-content-between">
            <span>SIP Peers / Trunks (@_peers.Count)</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="Refresh">⟳ Refresh</button>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Host</th>
                        <th>Status</th>
                        <th>Dynamic</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_peers.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">No peers</td></tr>
                    }
                    @foreach (var p in _peers)
                    {
                        <tr>
                            <td><strong>@p.Name</strong></td>
                            <td>@p.IpAddress</td>
                            <td>
                                <span class="badge bg-@(p.Status?.Contains("OK") == true ? "success" : "danger")">
                                    @p.Status
                                </span>
                            </td>
                            <td>@(p.Dynamic ? "Dynamic" : "Static")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private IReadOnlyList<AsteriskPeer> _peers = [];
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        Refresh();
        _timer = new System.Threading.Timer(_ =>
            InvokeAsync(() => { Refresh(); StateHasChanged(); }), null, 10000, 10000);
    }

    private void Refresh() => _peers = AsteriskService.GetPeers();
    public void Dispose() => _timer?.Dispose();
}
