@page "/users"
@inject IAsteriskServerService AsteriskService

<PageTitle>Users — AsteriskConsole</PageTitle>

<h1>Users</h1>

@if (!AsteriskService.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a href="connect">Connect →</a></div>
}
else
{
    <ConfigAccessAlert />
}

@if (AsteriskService.IsConnected && AsteriskService.HasConfigAccess)
{
    var users = AsteriskService.Server?.ConfigManager?.Users?.ToList() ?? [];
    <div class="d-flex justify-content-between mb-3">
        <span class="text-muted">@users.Count user(s)</span>
    </div>
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Extension</th>
                        <th>Name</th>
                        <th>Context</th>
                        <th>Codec</th>
                        <th>Voicemail</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td><strong>@user.Extension</strong></td>
                            <td>@user.FullName</td>
                            <td><code>@user.Context</code></td>
                            <td>@user.Allow</td>
                            <td>@(user.HasVoicemail ? "✓" : "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
