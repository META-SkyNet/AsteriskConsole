@page "/cdr"
@inject IAsteriskServerService AsteriskService

<PageTitle>Call Detail Records — AsteriskConsole</PageTitle>

<h1>Call Detail Records</h1>

@if (!AsteriskService.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a href="connect">Connect →</a></div>
}
else
{
    var records = AsteriskService.GetCallDetailRecords();
    <div class="mb-2 text-muted">@records.Count record(s)</div>
    <div class="card">
        <div class="card-body p-0">
            <div style="overflow-x:auto">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Date/Time</th>
                            <th>Source</th>
                            <th>Destination</th>
                            <th>Duration</th>
                            <th>Disposition</th>
                            <th>Channel</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!records.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-3">No records available.</td></tr>
                        }
                        @foreach (var r in records.OrderByDescending(x => x.StartDate).Take(500))
                        {
                            <tr>
                                <td class="small">@r.StartDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@r.Channel?.Name</td>
                                <td>@r.DestinationExtension</td>
                                <td>@r.Duration</td>
                                <td>
                                    <span class="badge bg-@DispositionColor(r.Disposition.ToString())">
                                        @r.Disposition
                                    </span>
                                </td>
                                <td class="small"><code>@r.DestinationChannel?.Name</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private static string DispositionColor(string? d) => d?.ToUpper() switch
    {
        "ANSWERED" => "success",
        "BUSY" => "warning",
        "NO ANSWER" => "secondary",
        "FAILED" => "danger",
        _ => "light"
    };
}
